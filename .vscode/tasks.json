{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-youhavetosay-api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/YouHaveToSay.Api/YouHaveToSay.Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "setup-turkish-keyboard-ios",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/setup-turkish-keyboard-ios.sh",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "setup-turkish-keyboard-android",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/setup-turkish-keyboard-android.sh",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
